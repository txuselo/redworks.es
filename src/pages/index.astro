---
export const prerender = true;

import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import CtaBand from '../components/CtaBand.astro';
import BrandsStrip from '../components/BrandsStrip.astro';
import FAQ from '../components/FAQ.astro';
import { faqPageSchema } from '../lib/faqSchema';

const HOME_FAQS = [
  {
    question: '¿Qué servicios ofrece Redworks Solutions?',
    answer:
      'Instalamos y mantenemos sistemas de telecomunicaciones (redes, wifi, VoIP, videoconferencia, megafonía), electricidad de baja tensión, seguridad (CCTV y control de accesos) y energía solar fotovoltaica para empresas en Madrid.',
  },
  {
    question: '¿En qué zonas trabaja Redworks?',
    answer:
      'Trabajamos principalmente en Madrid y su área metropolitana, con proyectos puntuales en el resto de España según las necesidades del cliente.',
  },
  {
    question: '¿Cuánta experiencia tiene Redworks Solutions?',
    answer:
      'Más de 15 años instalando y manteniendo sistemas de telecomunicaciones, electricidad y energías renovables para empresas de todos los tamaños.',
  },
  {
    question: '¿Ofrecéis presupuesto sin compromiso?',
    answer:
      'Sí, estudiamos cada proyecto y preparamos un presupuesto sin compromiso adaptado a las necesidades concretas de tu negocio antes de empezar cualquier instalación.',
  },
];

// Port-style codes, like the labels on a patch panel or breaker box — a structural
// device that actually means something for an installer of this kind of equipment.
const SERVICE_CODES: Record<string, string> = {
  telecomunicaciones: 'NET',
  'telefonia-voip': 'VOIP',
  audiovisuales: 'A/V',
  videoconferencias: 'VC',
  megafonia: 'MEG',
  conferencias: 'SALA',
  'sistemas-informaticos': 'LAN',
  'redes-wifi': 'WIFI',
  seguridad: 'CCTV',
  electricidad: 'ELEC',
  paneles: 'FV',
  'instalacion-electrica-de-baja-tension': 'BT',
};

const services = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);

const whyRedworks = [
  {
    icon: 'shield-alt',
    title: 'Experiencia',
    body: 'Más de 15 años de experiencia y un equipo certificado.',
  },
  {
    icon: 'check-circle',
    title: 'Resultados',
    body: 'Profesionales especializados que cuidan cada detalle del proyecto.',
  },
  {
    icon: 'headset',
    title: 'Dedicación',
    body: 'Soluciones a medida, adaptadas a lo que necesita tu negocio.',
  },
];
---

<Layout
  title="Empresa Telecomunicaciones y Electricidad Madrid | Redworks"
  description="Empresa Instaladora de Sistemas de Telecomunicaciones y Sistemas de Electricidad en Madrid. Más de 15 años de experiencia. 910 52 74 99"
  schema={[faqPageSchema(HOME_FAQS)]}
>
  <Hero title="Telecomunicaciones y electricidad para tu negocio en Madrid" eyebrow="Madrid · Instalador certificado" dark>
    Más de 15 años instalando y manteniendo sistemas de telecomunicaciones, electricidad y energías
    renovables para empresas.
  </Hero>

  <section class="container services">
    <p class="eyebrow">Catálogo de servicios</p>
    <h2>Once líneas de instalación, un solo equipo</h2>
    <div class="grid">
      {
        services.map((service) => (
          <a
            class="node"
            data-category={service.data.category}
            href={`/${service.id}/`}
          >
            <span class="code">{SERVICE_CODES[service.id] ?? '—'}</span>
            <span class="label">{service.data.navLabel}</span>
          </a>
        ))
      }
    </div>
  </section>

  <WhyChooseUs cards={whyRedworks} />
  <FAQ items={HOME_FAQS} title="Preguntas frecuentes" />
  <CtaBand />
  <BrandsStrip />
</Layout>

<style>
  .services {
    padding: 4rem 0 3.5rem;
  }
  .services h2 {
    max-width: 18ch;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    margin-top: 2.5rem;
    background: var(--wire);
    border: 1px solid var(--wire);
  }
  .node {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 1.25rem;
    background: var(--white);
    color: var(--text);
    border-top: 3px solid var(--blue);
  }
  .node[data-category='electricidad'] {
    border-top-color: var(--red);
  }
  .node .code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--blue);
  }
  .node[data-category='electricidad'] .code {
    color: var(--red);
  }
  .node .label {
    font-weight: 600;
    font-size: 0.98rem;
  }
  .node:hover {
    background: var(--paper);
    text-decoration: none;
  }
</style>
