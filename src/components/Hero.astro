---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  image?: ImageMetadata;
}
const { title, image } = Astro.props;
---

<section class="hero">
  {image && <Image src={image} alt="" class="hero-bg" width={1600} height={700} />}
  <div class="container">
    <h1>{title}</h1>
    <p><slot /></p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 4rem 0;
    background: var(--color-bg-alt);
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
    z-index: 0;
  }
  .hero .container {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }
  .hero h1 {
    font-size: 2.25rem;
    color: var(--color-primary-dark);
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--color-text);
  }
</style>
