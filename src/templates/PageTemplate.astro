---
import type { CollectionEntry } from 'astro:content';
import { render, getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

interface Props {
  entry: CollectionEntry<'pages'>;
}
const { entry } = Astro.props;
const { title, metaDescription, heroTitle } = entry.data;
const { Content } = await render(entry);

const TEAM = [
  { photo: 'felipe', name: 'Felipe Aguilar', role: 'CEO y Fundador' },
  { photo: 'maria', name: 'María Pérez', role: 'Directora de Estrategia Técnica' },
  { photo: 'rocio', name: 'Rocío Crespo', role: 'Directora Financiera' },
  { photo: 'jose-maria', name: 'Jose María Soler', role: 'Director Comercial' },
  { photo: 'ibrahim', name: 'Ibrahim Benzian', role: 'Equipo técnico' },
  { photo: 'angel', name: 'Ángel Herranz', role: 'Equipo técnico' },
  { photo: 'chema', name: 'Chema Cerezo', role: 'Equipo técnico' },
  { photo: 'javier', name: 'Javier Mesías', role: 'Equipo técnico' },
];

const teamPhotos = import.meta.glob<{ default: ImageMetadata }>('../assets/shared/team/*.jpg', {
  eager: true,
});
const teamWithPhotos = TEAM.map((member) => ({
  ...member,
  image: teamPhotos[`../assets/shared/team/${member.photo}.jpg`]?.default,
}));

const clientPhotos = import.meta.glob<{ default: ImageMetadata }>('../assets/shared/clients/*.png', {
  eager: true,
});
const clientLogos = Object.values(clientPhotos).map((mod) => mod.default);

const services = entry.id === 'telecomunicaciones' ? await getCollection('services') : [];
const telecomServices = services
  .filter((s) => s.data.category === 'telecomunicaciones')
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout title={title} description={metaDescription}>
  <Hero title={heroTitle}>
    <Content />
  </Hero>

  {
    entry.id === 'quienes-somos' && (
      <section class="container team">
        <h2>Nuestro equipo</h2>
        <div class="team-grid">
          {teamWithPhotos.map((member) => (
            <div class="team-card">
              {member.image && <Image src={member.image} alt={member.name} width={200} height={220} />}
              <p class="name">{member.name}</p>
              <p class="role">{member.role}</p>
            </div>
          ))}
        </div>
      </section>
    )
  }

  {
    entry.id === 'clientes' && (
      <div class="container client-logos">
        {clientLogos.map((logo) => (
          <Image src={logo} alt="" width={120} height={120} loading="lazy" />
        ))}
      </div>
    )
  }

  {
    entry.id === 'telecomunicaciones' && (
      <section class="container telecom-grid">
        {telecomServices.map((service) => (
          <a class="service-link" href={`/${service.id}/`}>
            {service.data.navLabel}
          </a>
        ))}
      </section>
    )
  }
</Layout>

<style>
  .team {
    padding: 2rem 0 3rem;
    text-align: center;
  }
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .team-card img {
    border-radius: var(--radius);
    width: 100%;
    aspect-ratio: 4 / 4.4;
    object-fit: cover;
    margin-bottom: 0.5rem;
  }
  .team-card .name {
    font-weight: 700;
    margin: 0;
  }
  .team-card .role {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }
  .client-logos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: 1.5rem;
    padding-bottom: 3rem;
  }
  .client-logos img {
    width: 100%;
    max-width: 110px;
    margin: 0 auto;
    filter: grayscale(1);
    opacity: 0.8;
  }
  .telecom-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    padding-bottom: 3rem;
  }
  .service-link {
    display: block;
    padding: 1.25rem;
    border: 1px solid #eee;
    border-radius: var(--radius);
    font-weight: 600;
    color: var(--color-text);
    text-align: center;
  }
  .service-link:hover {
    border-color: var(--color-primary);
    text-decoration: none;
    background: var(--color-bg-alt);
  }
</style>
